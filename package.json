{
  "name": "pixelyph",
  "version": "0.0.1",
  "private": true,
  "description": "A pixel-art creation tool that traces artwork into scalable SVG (and real font files) via pixelloom.",
  "author": "Pixelyph",
  "type": "module",
  "main": "out/main/index.js",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test": "node --test",
    "electron:dev": "electron-vite dev",
    "electron:build": "electron-vite build",
    "electron:preview": "electron-vite preview",
    "dist:win": "electron-vite build && electron-builder --win"
  },
  "dependencies": {
    "buffer": "^6.0.3",
    "gifenc": "^1.0.3",
    "opentype.js": "^2.0.0",
    "pixelloom": "^0.1.1",
    "quantize": "^1.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "ttf2woff": "^3.0.0",
    "upng-js": "^2.1.0",
    "wawoff2": "^2.0.1",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@types/node": "^18.19.0",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^43.0.0",
    "electron-builder": "^26.15.3",
    "electron-vite": "^5.0.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.0"
  },
  "license": "MIT",
  "build": {
    "appId": "com.pixelyph.app",
    "productName": "Pixelyph",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": "nsis"
    }
  }
}
